# Base URL of the mail backend used by the contact form and newsletter.
# Copy this file to `.env` and adjust as needed.
#
# Leave EMPTY for same-origin PHP scripts on LWS mutualisé:
#   the app then calls /send-mail and /newsletter on its own domain,
#   which .htaccess routes to send-mail.php / newsletter.php.
# Set a full URL (e.g. https://api.example.com) only if the backend
# lives on another host.
VITE_API_URL=
